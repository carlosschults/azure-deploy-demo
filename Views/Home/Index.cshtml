@{
    ViewData["Title"] = "Home Page";
    var environment = ViewData["Environment"]?.ToString();
    var slotName = ViewData["Slot"]?.ToString();
    var isProd = environment == "Prod";
}

<div class="text-center">
    <h1 class="display-4">Azure App Services Demo</h1>

    <table class="table table-bordered w-50 mx-auto mt-4">
        <tr>
            <th>.NET Version</th>
            <td>@ViewData["DotNetVersion"]</td>
        </tr>
        <tr>
            <th>Environment</th>
            <td>@environment</td>
        </tr>
        <tr>
            <th>Slot</th>
            <td>@slotName</td>
        </tr>
        @if (isProd)
        {
            <tr>
                <th>Active slot</th>
                <td>
                    @if (slotName == "production")
                    {
                        <span class="badge bg-success">Live</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Staging</span>
                    }
                </td>
            </tr>
        }
        <tr>
            <th>Config Non-Sensitive Value</th>
            <td>
                @if (ViewData["Value"]?.ToString() == "Not found")
                {
                    <span class="badge bg-danger">Not found ✗</span>
                }
                else
                {
                    <span>@ViewData["Value"]</span>
                }
            </td>
        </tr>
        <tr>
            <th>Config Secret</th>
            <td>
                @if (ViewData["Secret"]?.ToString() == "Not found")
                {
                    <span class="badge bg-danger">Not found ✗</span>
                }
                else
                {
                    <code>@ViewData["Secret"]</code>
                }
            </td>
        </tr>
    </table>
</div>